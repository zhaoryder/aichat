{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "inputs": [{ "local": true, "include": ["."] }],
      "commands": ["cd server && npm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["cd server && npm run build"]
    }
  },
  "deploy": {
    "startCommand": "node server/dist/index.js"
  }
}
