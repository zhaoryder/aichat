{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "src": "server/package.json", "dest": "package.json" },
        { "src": "server/package-lock.json", "dest": "package-lock.json" },
        "npm install"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        { "src": "server/src", "dest": "src" },
        { "src": "server/shared", "dest": "shared" },
        { "src": "server/tsconfig.json", "dest": "tsconfig.json" },
        "npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node dist/index.js"
  }
}
