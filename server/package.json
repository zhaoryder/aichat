{
  "name": "aichat-server",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env.local src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --packages=external --platform=node --target=node20 --outfile=dist/index.js --format=esm",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@supabase/supabase-js": "^2.110.2",
    "ai": "^7.0.22",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.43",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
